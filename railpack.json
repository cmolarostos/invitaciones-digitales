{
    "provider": "php",
    "phpVersion": "8.4",
    "extensions": [
        "gd",
        "pdo",
        "pdo_mysql",
        "mbstring",
        "tokenizer",
        "xml",
        "ctype",
        "fileinfo",
        "curl",
        "zip",
        "bcmath",
        "intl"
    ],
    "build": {
        "env": {
            "COMPOSER_ALLOW_SUPERUSER": "1"
        },
        "cmds": [
            "npm ci",
            "npm run build",
            "php artisan config:cache",
            "php artisan route:cache",
            "php artisan view:cache"
        ]
    },
    "start": {
        "cmd": "php artisan migrate --force && php artisan db:seed --force && php artisan serve --host=0.0.0.0 --port=$PORT"
    }
}
